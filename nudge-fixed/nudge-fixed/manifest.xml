<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">

  <!-- ══ Identity ══════════════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Email Nudge</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Email Nudge"/>
  <Description DefaultValue="Surfaces emails waiting for your reply and nudges you to follow up — right inside Outlook."/>

  <!-- ══ Icons ════════════════════════════════════════════════════════════ -->
  <IconUrl DefaultValue="https://outlook-nudge-2-0.onrender.com/icons/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://outlook-nudge-2-0.onrender.com/icons/icon-64.png"/>
  <SupportUrl DefaultValue="https://outlook-nudge-2-0.onrender.com"/>

  <!-- ══ App domains ═══════════════════════════════════════════════════════ -->
  <AppDomains>
    <AppDomain>https://outlook-nudge-2-0.onrender.com</AppDomain>
  </AppDomains>

  <!-- ══ Host requirements ════════════════════════════════════════════════ -->
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <!-- ══ Form settings (legacy / Outlook 2016) ════════════════════════════ -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://outlook-nudge-2-0.onrender.com/taskpane.html"/>
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ══ Permissions ══════════════════════════════════════════════════════ -->
  <Permissions>ReadWriteMailbox</Permissions>

  <!-- ══ Activation rule (shows add-in for every email) ══════════════════ -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ══ Version overrides (ribbon button + task pane) ═══════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets>
          <bt:Set Name="Mailbox" MinVersion="1.5"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- ── Desktop Outlook ─────────────────────────────────────────── -->
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url"/>

            <!-- Message Read surface (ribbon button) -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="nudgeTaskPaneButton">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId1</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- Message Compose surface (ribbon button) -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="nudgeComposeButton">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId2</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>

          <!-- ── Mobile (Outlook for iOS / Android) ────────────────────── -->
          <MobileFormFactor>
            <ExtensionPoint xsi:type="MobileMessageReadCommandSurface">
              <Control xsi:type="MobileButton" id="nudgeMobileButton">
                <Label resid="TaskpaneButton.Label"/>
                <Icon>
                  <bt:Image size="25" scale="1" resid="Icon.32x32"/>
                  <bt:Image size="32" scale="2" resid="Icon.32x32"/>
                  <bt:Image size="48" scale="3" resid="Icon.32x32"/>
                </Icon>
                <Action xsi:type="ShowTaskpane">
                  <SourceLocation resid="Taskpane.Url"/>
                </Action>
              </Control>
            </ExtensionPoint>
          </MobileFormFactor>

        </Host>
      </Hosts>

      <!-- ── Resources ──────────────────────────────────────────────────── -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://outlook-nudge-2-0.onrender.com/icons/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://outlook-nudge-2-0.onrender.com/icons/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://outlook-nudge-2-0.onrender.com/icons/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://outlook-nudge-2-0.onrender.com/commands.html"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://outlook-nudge-2-0.onrender.com/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Email Nudge"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="Email Nudge"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open Email Nudge — see replies waiting on you and threads awaiting responses."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
